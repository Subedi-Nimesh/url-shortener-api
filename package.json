{
  "name": "url-shortener-api",
  "version": "1.0.0",
  "description": "URL Shortener REST API with JWT auth, PostgreSQL, and Swagger docs",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
